{
  "name": "@sellify/common-ui-components",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "exports": {
    "./types": "./src/types.d.ts",
    "./constants": "./src/constants.ts",
    "./styles": "./styles/globals.css",
    "./*": "./src/*.tsx",
    "./**/*": "./src/**/*.tsx"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "lint": "eslint . --fix --max-warnings 0",
    "lint:strict": "eslint . --max-warnings 0",
    "clean": "git clean -xdf .cache .turbo dist node_modules .coverage",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage"
  },
  "peerDependencies": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@sellify/common-icons": "workspace:*",
    "@sellify/eslint-config": "workspace:*",
    "@sellify/tailwind-config": "workspace:*",
    "@sellify/typescript-config": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.8",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "tailwindcss": "~4.1.18",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.3"
  }
