{
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false,
      "dependsOn": ["^clean"]
    },
    "test:e2e": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^test:e2e"]
    },
    "test:unit": {
      "cache": false,
      "dependsOn": ["^test:unit"]
    }
  }
}
